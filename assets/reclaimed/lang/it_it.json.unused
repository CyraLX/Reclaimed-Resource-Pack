{
    "reclaimed": "Reclaimed",
    "advancements.reclaimed.aspect.dragonkin.root": "Aspect: Dragonide",
    "advancements.reclaimed.aspect.dragonkin.root.description": "Scegli di diventare un Dragonide",
    "advancements.reclaimed.aspect.dragonkin.root.lore": "Dragon Mommy!",
    "advancements.reclaimed.aspect.frostling.root": "Aspect: Ghiaccino",
    "advancements.reclaimed.aspect.frostling.root.description": "Scegli di Diventare un Ghiaccino",
    "advancements.reclaimed.aspect.frostling.root.lore": "It snew",
    "advancements.reclaimed.aspect.morphling.form.aquatic": "Corpo Incantato",
    "advancements.reclaimed.aspect.morphling.form.aquatic.description": "Usa %1$s o più livelli per incantare un oggetto e rimanere con almeno %2$s livelli per sbloccare una nuova strada",
    "advancements.reclaimed.aspect.morphling.form.aquatic.lore": "La magia è intorno a te, e grazie ad essa tu riesci a vedere delle parti mancanti di te, chissà quali sono...",
    "advancements.reclaimed.aspect.morphling.form.fire": "Resti del Fuoco",
    "advancements.reclaimed.aspect.morphling.form.fire.description": "Uccidi un %1$s che è in fiamme nel Nether per accedere alla tua forma %2$s",
    "advancements.reclaimed.aspect.morphling.form.fire.lore": "%s è la pietra angolare del Nether e non hai perso tempo per prenderla tutta...",
    "advancements.reclaimed.aspect.morphling.form.void": "Vuoto Senza Limite",
    "advancements.reclaimed.aspect.morphling.form.void.description": "Consuma un %1$s mentre indossi un %2$s nell'End per ottenere l'accesso alla tua forma %3$s",
    "advancements.reclaimed.aspect.morphling.form.void.lore": "Tu non sei un %s, tu sei te stesso, ricordalo...",
    "advancements.reclaimed.aspect.morphling.root": "Aspect: Morphling",
    "advancements.reclaimed.aspect.morphling.root.description": "Scegli di Diventare un Morphling",
    "advancements.reclaimed.aspect.morphling.root.lore": "Un abitante dell'oceano in continua evoluzione, abbastanza audace da cambiare fino al midollo",
    "advancements.reclaimed.aspect.pebblemite.root": "Aspect: Sassetto",
    "advancements.reclaimed.aspect.pebblemite.root.description": "Scegli di Diventare un Sassetto",
    "advancements.reclaimed.aspect.pebblemite.root.lore": "Va bene che sei fatti di pietra, ma non sei \"The Rock\"",
    "advancements.reclaimed.aspect.phoenix.root": "Aspect: Fenice",
    "advancements.reclaimed.aspect.phoenix.root.description": "Scegli di Diventare una Fenice",
    "advancements.reclaimed.aspect.phoenix.root.lore": "Cacciatori di fiamme spericolati che prosperano nel pericolo",
    "advancements.reclaimed.aspect.remnant.root": "Aspect: Residuo",
    "advancements.reclaimed.aspect.remnant.root.description": "Scegli di Diventare un Residuo",
    "advancements.reclaimed.aspect.remnant.root.lore": "Il passato è dove è bloccato, beh... a volte",
    "advancements.reclaimed.aspect.voidborne.root": "Aspect: Voidborne",
    "advancements.reclaimed.aspect.voidborne.root.description": "Scegli di Diventare un Voidborne",
