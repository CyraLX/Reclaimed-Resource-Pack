    "item.reclaimed.focus.morphling.use_result_1": "Forza la tua forma a ciò su cui è sintonizzato il Focus",
    "item.reclaimed.focus.morphling.use_result_2": "Riporta il Focus sulla variante %s",
    "item.reclaimed.focus.morphling.use_result_3": "Riporta il Focus sulla variante %s",
    "item.reclaimed.focus.morphling.use_result_4": "Riporta il Focus alla tua forma attiva",
    "item.reclaimed.focus.morphling.use_result_4_1": "Sfrecciare nell'acqua con un'improvvisa accelerazione",
