    "config.reclaimed.morphling.morph_cooldown": "Raffreddamento Morph Del Morphling",
    "config.reclaimed.morphling.morph_cooldown.description": "Quanto dura il tempo di ricarica della trasformazione per i Morphling (in mezzi secondi).",
    "config.reclaimed.morphling.morph_cooldown.note": "(Ad esempio, 10 verrà interpretato come 5 secondi; i valori pari o inferiori a 0 saranno considerati istantanei)",
    "config.reclaimed.morphling.morph_duration": "Durata del Morph Del Morphling",
    "config.reclaimed.morphling.morph_duration.description": "Quanto tempo impiegano i Morphling a trasformarsi in una forma diversa (in mezzi secondi).",
    "config.reclaimed.morphling.morph_duration.note": "(Ad esempio, 10 verrà interpretato come 5 secondi; i valori pari o inferiori a 0 saranno considerati istantanei)",
    "config.reclaimed.pebblemite.teleport_distance": "Distanza Teletrasporto Del Focus del Pebblemite",
    "config.reclaimed.pebblemite.teleport_distance.description": "Quanto lontano Pebblemite può teletrasportarsi in avanti usando il Focus in 1/10 di blocchi",
    "config.reclaimed.pebblemite.teleport_distance.note": "(Ad esempio, 50 verrà interpretato come 5 blocchi)",
    "config.reclaimed.voidborne.storage_cap": "Limite di stoccaggio dei mob del Voidborne",
    "config.reclaimed.voidborne.storage_cap.description": "Quante entità Voidborne può contenere contemporaneamente.",
    "config.reclaimed.voidborne.storage_cap.note": "(Il valore 0 viene considerato come disabilitato, mentre i valori negativi vengono considerati come infiniti)",
    "config.reclaimed.voidborne.storage_hp_threshold": "Soglia di HP per l'immagazzinamento dei mob del Voidborne",
    "config.reclaimed.voidborne.storage_hp_threshold.description": "Quanti HP può avere l'entità prima che non possa più essere immagazzinata dal Voidborne.",
    "config.reclaimed.voidborne.storage_hp_threshold.note": "(Il valore 0 viene considerato come disabilitato, mentre i valori negativi vengono considerati come infiniti)",
